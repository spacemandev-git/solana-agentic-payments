# Postgres
DATABASE_URL=postgres://workshop:workshop@localhost:5433/events

# Surfpool RPC (local mainnet fork)
SOLANA_RPC_URL=http://127.0.0.1:8899

# USDC mint — mainnet USDC (surfpool forks from mainnet so this works locally)
USDC_MINT=EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v

# CAIP-2 network identifier — surfpool forks mainnet so we use mainnet's id.
# If you reset surfpool to devnet use solana:EtWTRABZaYq6iMfeYKouRu166VU2xqa1
X402_NETWORK=solana:5eykt4UsFv8P8NJdTREpY1vzqKqZKvdp

# Populated by `bun run setup`
SERVER_WALLET_SECRET=
SERVER_WALLET_ADDRESS=
FACILITATOR_WALLET_SECRET=
FACILITATOR_WALLET_ADDRESS=

# Internal: the facilitator runs in-process on this port
FACILITATOR_URL=http://127.0.0.1:4020
API_PORT=4021
