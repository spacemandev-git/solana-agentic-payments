# Postgres (uses 5434 so it doesn't clash with the x402 solution on 5433)
DATABASE_URL=postgres://workshop:workshop@localhost:5434/events

# Surfpool RPC (local mainnet fork)
SOLANA_RPC_URL=http://127.0.0.1:8899

# USDC mint — mainnet USDC (surfpool forks from mainnet)
USDC_MINT=EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v

# MPP network identifier (see @solana/mpp constants.ts)
# "mainnet-beta" | "devnet" | "localnet"
# Surfpool forks mainnet, so "mainnet-beta" is correct even locally.
MPP_NETWORK=mainnet-beta

# Secret used by Mppx to sign challenges (any random string)
MPP_SECRET_KEY=dev-only-replace-me

# Populated by `bun run setup`
SERVER_WALLET_SECRET=
SERVER_WALLET_ADDRESS=

API_PORT=4022
